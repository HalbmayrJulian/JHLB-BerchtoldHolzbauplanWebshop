@model int

<a asp-page="/Compare" class="nav-link position-relative">
    <i class="bi bi-clipboard-check"></i>
    Vergleichen
    @if (Model > 0)
    {
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary">
            @Model
            <span class="visually-hidden">Produkte im Vergleich</span>
        </span>
    }
</a>
