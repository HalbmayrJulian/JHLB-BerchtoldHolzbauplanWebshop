@page "{orderId:int}"
@model OrderConfirmationModel
@{
    ViewData["Title"] = "Bestellung erfolgreich";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <!-- Erfolgs-Card -->
            <div class="card border-success shadow">
                <div class="card-body text-center py-5">
                    <!-- Erfolgs-Icon -->
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h1 class="text-success mb-3">
                        Bestellung erfolgreich!
                    </h1>
                    
                    <p class="lead mb-4">
                        Vielen Dank für Ihre Bestellung!
                    </p>
                    
                    <p class="text-muted mb-4">
                        Ihre Bestellnummer: <strong>#@(1000 + Model.OrderId)</strong>
                    </p>

                    @if (!string.IsNullOrEmpty(Model.InvoicePdfPath))
                    {
                        <div class="alert alert-success mb-4">
                            <h5 class="alert-heading">
                                <i class="bi bi-file-earmark-pdf-fill"></i> Ihre Rechnung ist bereit!
                            </h5>
                            <p class="mb-3">
                                Ihre Rechnung wurde erfolgreich erstellt und kann jederzeit heruntergeladen werden.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="@Model.InvoicePdfPath" target="_blank" class="btn btn-success">
                                    <i class="bi bi-download"></i> Rechnung jetzt herunterladen
                                </a>
                                <a href="/MyOrders#invoices" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-folder2-open"></i> Alle Rechnungen ansehen
                                </a>
                            </div>
                        </div>
                    }

                    <hr class="my-4" />

                    <div class="d-grid gap-2">
                        <a asp-page="/MyOrders" class="btn btn-primary btn-lg">
                            <i class="bi bi-bag"></i> Meine Bestellungen
                        </a>
                        <a asp-page="/Index" class="btn btn-outline-success btn-lg">
                            <i class="bi bi-cart-plus"></i> Weiter einkaufen
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
