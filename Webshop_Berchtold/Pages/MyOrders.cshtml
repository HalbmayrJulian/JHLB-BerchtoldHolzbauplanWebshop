@page
@model MyOrdersModel
@{
    ViewData["Title"] = "Meine Bestellungen";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Startseite</a></li>
            <li class="breadcrumb-item active" aria-current="page">Meine Bestellungen</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="bi bi-bag"></i> Meine Bestellungen
            </h1>
        </div>
    </div>

    <!-- Statistiken -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Gesamtbestellungen</h5>
                    <h2 class="card-text text-primary">@Model.TotalOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Gesamtausgaben</h5>
                    <h2 class="card-text text-success">€@Model.TotalSpent.ToString("N2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Angezeigte Bestellungen</h5>
                    <h2 class="card-text text-info">@Model.Orders.Count</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter und Suche -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <label for="searchQuery" class="form-label">Suche</label>
                    <input type="text" class="form-control" id="searchQuery" name="searchQuery" 
                           value="@Model.SearchQuery" placeholder="Bestellnummer, Produkt oder Adresse...">
                </div>
                <div class="col-md-4">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="Alle" selected="@(Model.StatusFilter == "Alle" || string.IsNullOrEmpty(Model.StatusFilter))">Alle Status</option>
                        <option value="Bestellt" selected="@(Model.StatusFilter == "Bestellt")">Bestellt</option>
                        <option value="Versendet" selected="@(Model.StatusFilter == "Versendet")">Versendet</option>
                        <option value="Geliefert" selected="@(Model.StatusFilter == "Geliefert")">Geliefert</option>
                        <option value="Storniert" selected="@(Model.StatusFilter == "Storniert")">Storniert</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filtern
                    </button>
                </div>
            </form>
            @if (!string.IsNullOrEmpty(Model.SearchQuery) || (!string.IsNullOrEmpty(Model.StatusFilter) && Model.StatusFilter != "Alle"))
            {
                <div class="mt-3">
                    <a asp-page="/MyOrders" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Filter zurücksetzen
                    </a>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
        </div>
    }

    @if (!Model.Orders.Any())
    {
        @if (string.IsNullOrEmpty(Model.SearchQuery) && (string.IsNullOrEmpty(Model.StatusFilter) || Model.StatusFilter == "Alle"))
        {
            <div class="alert alert-info">
                <h4><i class="bi bi-inbox"></i> Noch keine Bestellungen</h4>
                <p>Sie haben noch keine Bestellungen aufgegeben.</p>
                <a asp-page="/Index" class="btn btn-primary mt-2">
                    <i class="bi bi-shop"></i> Jetzt einkaufen
                </a>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <h4><i class="bi bi-search"></i> Keine Bestellungen gefunden</h4>
                <p>Es wurden keine Bestellungen gefunden, die Ihren Suchkriterien entsprechen.</p>
                <a asp-page="/MyOrders" class="btn btn-outline-secondary mt-2">
                    <i class="bi bi-x-circle"></i> Filter zurücksetzen
                </a>
            </div>
        }
    }
    else
    {
        <div class="row">
            @foreach (var order in Model.Orders)
            {
                var statusColor = order.Status switch
                {
                    "Bestellt" => "warning",
                    "Versendet" => "info",
                    "Geliefert" => "success",
                    "Storniert" => "danger",
                    _ => "secondary"
                };

                var statusIcon = order.Status switch
                {
                    "Bestellt" => "bi-clock-history",
                    "Versendet" => "bi-truck",
                    "Geliefert" => "bi-check-circle",
                    "Storniert" => "bi-x-circle",
                    _ => "bi-question-circle"
                };

                <div class="col-12 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <small class="text-muted">Bestellnummer</small>
                                    <div class="fw-bold">#@(1000 + order.Id)</div>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Bestelldatum</small>
                                    <div class="fw-bold">@order.BestellDatum.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Gesamtbetrag</small>
                                    <div class="fw-bold text-success">€@order.GesamtBetrag.ToString("N2")</div>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Status</small>
                                    <div>
                                        <span class="badge bg-@statusColor">
                                            <i class="@statusIcon"></i> @order.Status
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <!-- Lieferadresse -->
                            <div class="mb-3">
                                <small class="text-muted">Lieferadresse:</small>
                                <div>
                                    @order.LieferAdresse
                                    @if (!string.IsNullOrEmpty(order.Postleitzahl) && !string.IsNullOrEmpty(order.Stadt))
                                    {
                                        <span>, @order.Postleitzahl @order.Stadt</span>
                                    }
                                    @if (!string.IsNullOrEmpty(order.Land))
                                    {
                                        <span>, @order.Land</span>
                                    }
                                </div>
                            </div>

                            <!-- Bestellte Artikel -->
                            <div class="mb-3">
                                <small class="text-muted fw-bold">
                                    Bestellte Artikel (@order.OrderItems.Count @(order.OrderItems.Count == 1 ? "Artikel" : "Artikel")):
                                </small>
                                <div class="mt-2">
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                            <div class="d-flex align-items-center flex-grow-1">
                                                @if (!string.IsNullOrEmpty(item.Product?.BildUrl))
                                                {
                                                    <img src="@item.Product.BildUrl" alt="@item.Product.Name" 
                                                         style="width: 50px; height: 50px; object-fit: cover;" class="me-3 rounded" />
                                                }
                                                else
                                                {
                                                    <i class="@(item.Product?.IconClass ?? "bi-box") me-3" 
                                                       style="font-size: 2rem; color: var(--color-medium-gray);"></i>
                                                }
                                                <div>
                                                    <div class="fw-bold">@(item.Product?.Name ?? "[Produkt gelöscht]")</div>
                                                    <small class="text-muted">
                                                        @item.Anzahl x €@item.EinzelPreis.ToString("N2")
                                                        @if (!string.IsNullOrEmpty(item.Product?.Einheit))
                                                        {
                                                            <span> (@item.Product.Einheit)</span>
                                                        }
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="text-end ms-3">
                                                <strong>€@item.GesamtPreis.ToString("N2")</strong>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Aktionen -->
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-page="/ProductDetail" asp-route-id="@order.OrderItems.First().ProductId" 
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-arrow-repeat"></i> Erneut bestellen
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
