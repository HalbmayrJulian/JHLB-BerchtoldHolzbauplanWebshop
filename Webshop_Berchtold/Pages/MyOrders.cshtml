@page
@model MyOrdersModel
@{
    ViewData["Title"] = "Meine Bestellungen";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Startseite</a></li>
            <li class="breadcrumb-item active" aria-current="page">Meine Bestellungen</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="bi bi-bag"></i> Meine Bestellungen
            </h1>
            <p class="text-muted">Sie haben insgesamt <strong>@Model.TotalOrders</strong> @(Model.TotalOrders == 1 ? "Bestellung" : "Bestellungen") aufgegeben.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
        </div>
    }

    @if (!Model.Orders.Any())
    {
        <div class="alert alert-info mt-4">
            <h4><i class="bi bi-inbox"></i> Noch keine Bestellungen</h4>
            <p>Sie haben noch keine Bestellungen aufgegeben.</p>
            <a asp-page="/Index" class="btn btn-primary mt-2">
                <i class="bi bi-shop"></i> Jetzt einkaufen
            </a>
        </div>
    }
    else
    {
        <div class="row mt-4">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12 mb-3">
                    <div class="card">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col-md-4">
                                    <small class="text-muted">Bestellnummer</small>
                                    <div class="fw-bold">#@(1000 + order.Id)</div>
                                </div>
                                <div class="col-md-4">
                                    <small class="text-muted">Datum</small>
                                    <div>@order.BestellDatum.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                                <div class="col-md-4">
                                    <small class="text-muted">Betrag</small>
                                    <div class="fw-bold text-success">€@order.GesamtBetrag.ToString("N2")</div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <!-- Lieferadresse -->
                            <div class="mb-3">
                                <small class="text-muted">Lieferadresse:</small>
                                <div>
                                    @order.LieferAdresse
                                    @if (!string.IsNullOrEmpty(order.Postleitzahl) && !string.IsNullOrEmpty(order.Stadt))
                                    {
                                        <span>, @order.Postleitzahl @order.Stadt</span>
                                    }
                                    @if (!string.IsNullOrEmpty(order.Land))
                                    {
                                        <span>, @order.Land</span>
                                    }
                                </div>
                            </div>

                            <!-- Bestellte Artikel -->
                            <div class="mb-3">
                                <small class="text-muted fw-bold">
                                    Bestellte Artikel (@order.OrderItems.Count @(order.OrderItems.Count == 1 ? "Artikel" : "Artikel")):
                                </small>
                                <div class="mt-2">
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                            <div class="d-flex align-items-center flex-grow-1">
                                                @if (!string.IsNullOrEmpty(item.Product?.BildUrl))
                                                {
                                                    <img src="@item.Product.BildUrl" alt="@item.Product.Name" 
                                                         style="width: 50px; height: 50px; object-fit: cover;" class="me-3 rounded" />
                                                }
                                                else
                                                {
                                                    <i class="@(item.Product?.IconClass ?? "bi-box") me-3" 
                                                       style="font-size: 2rem; color: var(--color-medium-gray);"></i>
                                                }
                                                <div>
                                                    <div class="fw-bold">@(item.Product?.Name ?? "[Produkt gelöscht]")</div>
                                                    <small class="text-muted">
                                                        @item.Anzahl x €@item.EinzelPreis.ToString("N2")
                                                        @if (!string.IsNullOrEmpty(item.Product?.Einheit))
                                                        {
                                                            <span> (@item.Product.Einheit)</span>
                                                        }
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="text-end ms-3">
                                                <strong>€@item.GesamtPreis.ToString("N2")</strong>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Aktionen -->
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-page="/ProductDetail" asp-route-id="@order.OrderItems.First().ProductId" 
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-arrow-repeat"></i> Erneut bestellen
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
