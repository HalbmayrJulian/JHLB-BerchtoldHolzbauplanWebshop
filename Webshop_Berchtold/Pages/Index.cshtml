@page
@using Microsoft.AspNetCore.Identity
@using Webshop_Berchtold.Models
@inject SignInManager<User> SignInManager
@model IndexModel
@{
    ViewData["Title"] = "Startseite";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                @if (SignInManager.IsSignedIn(User))
                {
                    var firstName = User.FindFirst("FirstName")?.Value ?? "Benutzer";
                    <h1 class="hero-title">Willkommen zurück, @firstName!</h1>
                    <p class="hero-subtitle">Entdecken Sie unsere neuesten Angebote und Ihre persönlichen Empfehlungen</p>
                }
                else
                {
                    <h1 class="hero-title">Ihr Partner für Holzbau</h1>
                    <p class="hero-subtitle">Hochwertige Materialien und Werkzeuge für professionelle Holzbaulösungen</p>
                }
                <div class="mt-4">
                    <a href="#products" class="btn btn-primary btn-lg me-3">Produkte entdecken</a>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a href="#" class="btn btn-success btn-lg">Meine Bestellungen</a>
                    }
                    else
                    {
                        <a href="#" class="btn btn-secondary btn-lg">Beratung anfragen</a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Kategorie Navigation -->
<div class="container">
    <div class="category-nav">
        <nav class="nav nav-pills justify-content-center">
            <a class="nav-link active" asp-page="/Index">Alle Produkte</a>
            @foreach (var category in Model.Categories)
            {
                <a class="nav-link" asp-page="/Index" asp-route-categoryId="@category.Id">@category.Name</a>
            }
        </nav>
    </div>
</div>

@if (Model.BestsellerProducts.Any())
{
    <section class="container mb-5" id="alle">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="category-title mb-0">
                <i class="bi bi-stars"></i> Top 3 Bestseller
            </h2>
            <span class="badge bg-success">Bestseller</span>
        </div>

        <div class="row">
            @foreach (var bestseller in Model.BestsellerProducts)
            {
                var product = bestseller.Product;
                var productIcon = !string.IsNullOrEmpty(product.IconClass) ? product.IconClass : "bi-box";
                var productUrl = $"/product/{product.Id}";

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card product-card h-100 border-success">
                        <a href="@productUrl" class="text-decoration-none text-dark">
                            <div class="product-image bg-light d-flex align-items-center justify-content-center">
                                @if (!string.IsNullOrEmpty(product.BildUrl))
                                {
                                    <img src="@product.BildUrl" alt="@product.Name" class="img-fluid" />
                                }
                                else
                                {
                                    <i class="@productIcon" style="font-size: 3rem; color: var(--color-medium-gray);"></i>
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title product-title">@product.Name</h5>
                                <p class="card-text text-muted mb-2">@product.Beschreibung</p>
                                <span class="badge bg-success-subtle text-success-emphasis mb-2">Bestseller</span>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="product-price">€@product.Preis.ToString("N2")</span>
                                    <small class="text-muted">@bestseller.SoldQuantity x verkauft</small>
                                </div>
                            </div>
                        </a>
                        <div class="card-footer">
                            <a href="@productUrl" class="btn btn-primary w-100">
                                <i class="bi bi-eye"></i> Details ansehen
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- Produkte Section -->
<section id="products" class="container">
    @foreach (var category in Model.Categories)
    {
        if (Model.ProductsByCategory.ContainsKey(category.Id) && Model.ProductsByCategory[category.Id].Any())
        {
            var anchorId = $"category-{category.Id}";
            var products = Model.ProductsByCategory[category.Id];
            
            <!-- Kategorie Icon Mapping -->
            var categoryIcons = new Dictionary<string, string>
            {
                { "Schrauben und Verbindungen", "bi-tools" },
                { "Balken und Bretter", "bi-building" },
                { "Werkzeuge", "bi-hammer" },
                { "Dämmstoffe", "bi-house-fill" },
                { "Holzschutz", "bi-shield-fill-check" }
            };
            var categoryIcon = categoryIcons.ContainsKey(category.Name) ? categoryIcons[category.Name] : "bi-box";

            <div class="category-section" id="@anchorId">
                <h2 class="category-title">
                    <i class="@categoryIcon"></i> @category.Name
                </h2>
                <div class="row">
                    @foreach (var product in products)
                    {
                        var productIcon = !string.IsNullOrEmpty(product.IconClass) ? product.IconClass : "bi-box";
                        var productUrl = $"/product/{product.Id}";
                        
                        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                            <div class="card product-card h-100">
                                @if (SignInManager.IsSignedIn(User))
                                {
                                    var isInFavorites = Model.FavoriteProductIds.Contains(product.Id);
                                    var isInCompare = Model.CompareProductIds.Contains(product.Id);

                                    <div class="product-icon-buttons">
                                        @if (isInCompare)
                                        {
                                            <button class="btn btn-sm btn-compare-icon btn-compare-active" data-product-id="@product.Id" title="Aus Vergleich entfernen">
                                                <i class="bi bi-clipboard-check-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-compare-icon btn-add-compare" data-product-id="@product.Id" title="Zum Vergleich hinzufügen">
                                                <i class="bi bi-clipboard-check"></i>
                                            </button>
                                        }

                                        @if (isInFavorites)
                                        {
                                            <button class="btn btn-sm btn-favorite-icon btn-favorite-active" data-product-id="@product.Id" title="Aus Favoriten entfernen">
                                                <i class="bi bi-heart-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-favorite-icon btn-add-favorite" data-product-id="@product.Id" title="Zu Favoriten hinzufügen">
                                                <i class="bi bi-heart"></i>
                                            </button>
                                        }
                                    </div>
                                }
                                <a href="@productUrl" class="text-decoration-none text-dark">
                                    <div class="product-image bg-light d-flex align-items-center justify-content-center">
                                        @if (!string.IsNullOrEmpty(product.BildUrl))
                                        {
                                            <img src="@product.BildUrl" alt="@product.Name" class="img-fluid" />
                                        }
                                        else
                                        {
                                            <i class="@productIcon" style="font-size: 3rem; color: var(--color-medium-gray);"></i>
                                        }
                                    </div>
                                    <div class="card-body">
                                        <h5 class="card-title product-title">@product.Name</h5>
                                        <p class="card-text text-muted">@product.Beschreibung</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="product-price">€@product.Preis.ToString("N2")</span>
                                            <small class="text-muted">@product.Einheit</small>
                                        </div>
                                    </div>
                                </a>
                                <div class="card-footer">
                                    <a href="@productUrl" class="btn btn-primary w-100">
                                        <i class="bi bi-eye"></i> Details ansehen
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const selectedCategoryId = '@(Model.SelectedCategoryId?.ToString() ?? string.Empty)';
            if (selectedCategoryId) {
                window.addEventListener('load', function() {
                    const target = document.getElementById('category-' + selectedCategoryId);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            }

            const showMessage = window.showSiteToast || function(message) { console.warn(message); };

            // Favoriten Button Handler
            const favoriteButtons = document.querySelectorAll('.btn-add-favorite, .btn-favorite-active');

            favoriteButtons.forEach(button => {
                button.addEventListener('click', async function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const productId = this.getAttribute('data-product-id');
                    const icon = this.querySelector('i');
                    const isActive = this.classList.contains('btn-favorite-active');

                    try {
                        const response = await fetch(`/Favorites?handler=${isActive ? 'RemoveByProductId' : 'AddToFavorites'}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                            },
                            body: JSON.stringify({ productId: parseInt(productId) })
                        });

                        const result = await response.json();

                        if (result.success) {
                            if (isActive) {
                                icon.classList.remove('bi-heart-fill');
                                icon.classList.add('bi-heart');
                                this.classList.remove('btn-favorite-active');
                                this.title = 'Zu Favoriten hinzufügen';
                            } else {
                                icon.classList.remove('bi-heart');
                                icon.classList.add('bi-heart-fill');
                                this.classList.add('btn-favorite-active');
                                this.title = 'Aus Favoriten entfernen';
                            }

                            if (result.message) {
                                showMessage(result.message, 'success', 'Favoriten');
                            }
                        } else {
                            showMessage(result.message || 'Der Favorit konnte nicht geändert werden.', 'danger', 'Fehler');
                        }
                    } catch (error) {
                        console.error('Fehler:', error);
                        showMessage('Der Favorit konnte nicht geändert werden.', 'danger', 'Fehler');
                    }
                });
            });

            // Compare Button Handler
            const compareButtons = document.querySelectorAll('.btn-add-compare, .btn-compare-active');

            compareButtons.forEach(button => {
                button.addEventListener('click', async function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const productId = this.getAttribute('data-product-id');
                    const icon = this.querySelector('i');
                    const isActive = this.classList.contains('btn-compare-active');

                    try {
                        const response = await fetch(`/Compare?handler=${isActive ? 'RemoveByProductId' : 'AddToCompare'}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                            },
                            body: JSON.stringify({ productId: parseInt(productId) })
                        });

                        const result = await response.json();

                        if (result.success) {
                            if (isActive) {
                                icon.classList.remove('bi-clipboard-check-fill');
                                icon.classList.add('bi-clipboard-check');
                                this.classList.remove('btn-compare-active');
                                this.classList.add('btn-add-compare');
                                this.title = 'Zum Vergleich hinzufügen';
                            } else {
                                icon.classList.remove('bi-clipboard-check');
                                icon.classList.add('bi-clipboard-check-fill');
                                this.classList.remove('btn-add-compare');
                                this.classList.add('btn-compare-active');
                                this.title = 'Aus Vergleich entfernen';
                            }

                            if (result.message) {
                                showMessage(result.message, 'success', 'Vergleich');
                            }
                        } else {
                            showMessage(result.message || 'Der Vergleich konnte nicht geändert werden.', 'danger', 'Fehler');
                        }
                    } catch (error) {
                        console.error('Fehler:', error);
                        showMessage('Der Vergleich konnte nicht geändert werden.', 'danger', 'Fehler');
                    }
                });
            });
        });
    </script>
}
