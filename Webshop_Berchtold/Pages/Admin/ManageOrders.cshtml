@page
@model ManageOrdersModel
@{
    ViewData["Title"] = "Bestellungen";
}

<div class="container-fluid mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Startseite</a></li>
            <li class="breadcrumb-item"><a asp-page="/Admin">Admin Panel</a></li>
            <li class="breadcrumb-item active" aria-current="page">Bestellungen</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-box-seam"></i> Bestellungen
        </h1>

        <!-- Kleiner Filter -->
        <form method="get" class="d-flex gap-2" style="max-width: 400px;">
            <input type="text" class="form-control" name="searchQuery" 
                   value="@Model.SearchQuery" placeholder="Suche nach Kunde, E-Mail, Nr...">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a asp-page="/Admin/ManageOrders" class="btn btn-outline-secondary">
                    <i class="bi bi-x"></i>
                </a>
            }
        </form>
    </div>

    <!-- Statistiken -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="text-muted">Gesamtbestellungen</h5>
                    <h2 class="text-primary">@Model.TotalOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="text-muted">Gesamtumsatz</h5>
                    <h2 class="text-success">€@Model.TotalRevenue.ToString("N2")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Bestellungen -->
    @if (!Model.Orders.Any())
    {
        <div class="alert alert-info">
            <h4><i class="bi bi-inbox"></i> Keine Bestellungen gefunden</h4>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <p>Es wurden keine Bestellungen gefunden, die "<strong>@Model.SearchQuery</strong>" entsprechen.</p>
            }
            else
            {
                <p>Es wurden noch keine Bestellungen aufgegeben.</p>
            }
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12 mb-3">
                    <div class="card">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col-md-2">
                                    <small class="text-muted">Bestellnummer</small>
                                    <div class="fw-bold">#@order.OrderNumber</div>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Kunde</small>
                                    <div class="fw-bold">@order.CustomerName</div>
                                    <small class="text-muted">@order.CustomerEmail</small>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Datum</small>
                                    <div>@order.BestellDatum.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                                <div class="col-md-2">
                                    <small class="text-muted">Betrag</small>
                                    <div class="fw-bold text-success">€@order.GesamtBetrag.ToString("N2")</div>
                                </div>
                                <div class="col-md-2 text-end">
                                    @if (!string.IsNullOrEmpty(order.InvoicePdfPath))
                                    {
                                        <a href="@order.InvoicePdfPath" target="_blank" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-file-earmark-pdf"></i> Rechnung
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <small class="text-muted fw-bold">Bestellte Artikel:</small>
                            <div class="table-responsive mt-2">
                                <table class="table table-sm table-borderless mb-0">
                                    <thead>
                                        <tr class="text-muted" style="font-size: 0.85rem;">
                                            <th>Artikel</th>
                                            <th class="text-end">Anzahl</th>
                                            <th class="text-end">Einzelpreis</th>
                                            <th class="text-end">Gesamt</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in order.Items)
                                        {
                                            <tr>
                                                <td>@item.ProductName</td>
                                                <td class="text-end">@item.Anzahl x</td>
                                                <td class="text-end">€@item.EinzelPreis.ToString("N2")</td>
                                                <td class="text-end fw-bold">€@item.GesamtPreis.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
