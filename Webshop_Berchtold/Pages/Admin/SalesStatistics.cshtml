@page
@model Webshop_Berchtold.Pages.Admin.SalesStatisticsModel
@{
    ViewData["Title"] = "Verkaufsstatistiken";
}

<div class="admin-dashboard">
    <div class="container">
        <!-- Header -->
        <div class="admin-header">
            <h1 class="admin-title">
                <i class="bi bi-graph-up"></i>
                Verkaufsstatistiken
            </h1>
            <p class="admin-subtitle text-muted">Übersicht der meistverkauften Produkte und Lagerbestände</p>
            <hr class="admin-divider" />
        </div>

        <!-- Zeitraum-Filter -->
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">
                    <i class="bi bi-calendar-range"></i>
                    Zeitraum auswählen
                </h5>
                <div class="btn-group" role="group">
                    <a asp-page="/Admin/SalesStatistics" asp-route-period="7days" 
                       class="btn @(Model.SelectedPeriod == "7days" ? "btn-primary" : "btn-outline-primary")">
                        Letzte 7 Tage
                    </a>
                    <a asp-page="/Admin/SalesStatistics" asp-route-period="30days" 
                       class="btn @(Model.SelectedPeriod == "30days" ? "btn-primary" : "btn-outline-primary")">
                        Letzte 30 Tage
                    </a>
                    <a asp-page="/Admin/SalesStatistics" asp-route-period="90days" 
                       class="btn @(Model.SelectedPeriod == "90days" ? "btn-primary" : "btn-outline-primary")">
                        Letzte 90 Tage
                    </a>
                    <a asp-page="/Admin/SalesStatistics" asp-route-period="year" 
                       class="btn @(Model.SelectedPeriod == "year" ? "btn-primary" : "btn-outline-primary")">
                        Letztes Jahr
                    </a>
                    <a asp-page="/Admin/SalesStatistics" asp-route-period="all" 
                       class="btn @(Model.SelectedPeriod == "all" ? "btn-primary" : "btn-outline-primary")">
                        Gesamt
                    </a>
                </div>
            </div>
        </div>

        <!-- Übersicht Karten -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Abgeschlossene Bestellungen</h6>
                        <h2 class="card-title mb-0">@Model.TotalOrders</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Gesamtumsatz</h6>
                        <h2 class="card-title mb-0 text-success">€@Model.TotalRevenue.ToString("N2")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">Verschiedene Produkte verkauft</h6>
                        <h2 class="card-title mb-0">@Model.TopProducts.Count</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Verkaufsstatistik Tabelle -->
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-trophy"></i>
                    Top Verkaufsprodukte
                </h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.TopProducts.Any())
                {
                    <div class="alert alert-info m-3">
                        <i class="bi bi-info-circle"></i>
                        Keine Verkaufsdaten für den ausgewählten Zeitraum verfügbar.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50px;">Rang</th>
                                    <th>Produkt</th>
                                    <th>Kategorie</th>
                                    <th class="text-end">Verkauft</th>
                                    <th class="text-end">Umsatz</th>
                                    <th class="text-end">Ø Preis</th>
                                    <th class="text-end">Bestellungen</th>
                                    <th class="text-end">Lagerbestand</th>
                                    <th>Status</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rank = 1;
                                }
                                @foreach (var product in Model.TopProducts)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @(rank <= 3 ? "bg-warning" : "bg-secondary")">
                                                #@rank
                                            </span>
                                        </td>
                                        <td>
                                            <strong>@product.ProductName</strong>
                                            <br>
                                            <small class="text-muted">@product.Unit</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark">@product.CategoryName</span>
                                        </td>
                                        <td class="text-end">
                                            <strong>@product.TotalQuantitySold</strong>
                                        </td>
                                        <td class="text-end">
                                            <strong class="text-success">€@product.TotalRevenue.ToString("N2")</strong>
                                        </td>
                                        <td class="text-end">
                                            €@product.AveragePrice.ToString("N2")
                                        </td>
                                        <td class="text-end">
                                            @product.OrderCount
                                        </td>
                                        <td class="text-end">
                                            <strong class="@($"text-{product.StockStatusColor}")">
                                                @product.CurrentStock
                                            </strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-@product.StockStatusColor">
                                                @product.StockStatus
                                            </span>
                                        </td>
                                        <td>
                                            <a asp-page="/Admin/EditProduct" asp-route-id="@product.ProductId" 
                                               class="btn btn-sm btn-outline-primary" title="Produkt bearbeiten">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Hinweise und Empfehlungen -->
        @if (Model.TopProducts.Any(p => p.CurrentStock < 30))
        {
            <div class="card mt-4 border-warning">
                <div class="card-header bg-warning bg-opacity-10">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle text-warning"></i>
                        Lagerbestand-Warnungen
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Folgende beliebte Produkte haben einen niedrigen Lagerbestand:</strong>
                    </p>
                    <ul class="mb-0">
                        @foreach (var product in Model.TopProducts.Where(p => p.CurrentStock < 30).Take(5))
                        {
                            <li>
                                <strong>@product.ProductName</strong> - 
                                Nur noch <span class="text-danger">@product.CurrentStock</span> auf Lager 
                                (@product.TotalQuantitySold in @Model.SelectedPeriod verkauft)
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Zurück Button -->
        <div class="mt-4">
            <a asp-page="/Admin" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Zurück zum Admin-Dashboard
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Auto-refresh alle 5 Minuten
        // setTimeout(() => location.reload(), 300000);
    </script>
}
